# ============================================================
#  ShopOS Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file!
# ============================================================

# ── Database ────────────────────────────────────────────────
# Pooled connection (used by Prisma ORM for regular queries)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=5&pool_timeout=20"

# Direct connection (used by Prisma for migrations and analytics)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Authentication ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_GENERATE_64_BYTE_RANDOM_HEX"

# ── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://:PASSWORD@HOST:PORT"

# ── Frontend URL (exact, no trailing slash) ──────────────────
FRONTEND_URL="https://your-shop.netlify.app"
# Optional: for staging environment
# STAGING_URL="https://your-staging.netlify.app"

# ── Server ───────────────────────────────────────────────────
PORT=4001
NODE_ENV=production

# ── Google OAuth (optional) ──────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── Email (for password reset) ───────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"

# ── Cloudinary (for image uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── OpenAI (for AI features) ─────────────────────────────────
OPENAI_API_KEY=""

# ── Payments ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
STRIPE_SECRET_KEY=""

# ── Rate Limiting (optional overrides) ───────────────────────
# AUTH_RATE_LIMIT_MAX=10      # max auth attempts per window (default: 10)
# AUTH_RATE_LIMIT_WINDOW=900  # window in seconds (default: 900 = 15 min)

# ── Worker mode (for separate worker process deployment) ──────
# RUN_WORKERS=true  # set to "false" on API-only nodes
# RUN_API=true      # set to "false" on worker-only nodes
