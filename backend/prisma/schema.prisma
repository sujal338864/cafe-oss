// ============================================================
//  Shop OS — Prisma Schema
//  Database: PostgreSQL
//  ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum StockType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CREDIT
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum OrderStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ExpenseCategory {
  RENT
  ELECTRICITY
  SALARY
  MAINTENANCE
  MARKETING
  TRANSPORT
  OTHER
}

// ─────────────────────────────────────────────────────────────
// SHOP  (multi-tenant root)
// ─────────────────────────────────────────────────────────────

model Shop {
  id          String    @id @default(cuid())
  name        String
  ownerName   String
  phone       String
  email       String    @unique
  gstNumber   String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  currency    String    @default("INR")
  timezone    String    @default("Asia/Kolkata")
  logoUrl     String?
  plan        Plan      @default(STARTER)
  planExpiry  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users      User[]
  categories Category[]
  products   Product[]
  customers  Customer[]
  suppliers  Supplier[]
  orders     Order[]
  purchases  Purchase[]
  expenses   Expense[]
}

// ─────────────────────────────────────────────────────────────
// USER  (staff accounts per shop)
// ─────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name            String
  email           String
  passwordHash    String
  role            Role      @default(EMPLOYEE)
  isEmailVerified Boolean   @default(false)
  verifyToken     String?
  resetToken      String?
  resetExpiry     DateTime?
  lastLogin       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders  Order[]

  @@unique([email, shopId])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime  @default(now())

  products  Product[]

  @@unique([shopId, name])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// PRODUCT  (inventory)
// ─────────────────────────────────────────────────────────────

model Product {
  id            String    @id @default(cuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  name          String
  sku           String?
  barcode       String?
  description   String?
  costPrice     Decimal   @db.Decimal(10, 2)
  sellingPrice  Decimal   @db.Decimal(10, 2)
  taxRate       Decimal   @default(0) @db.Decimal(5, 2)
  stock         Int       @default(0)
  lowStockAlert Int       @default(10)
  unit          String    @default("pcs")
  imageUrl      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orderItems    OrderItem[]
  purchaseItems PurchaseItem[]
  stockHistory  StockHistory[]

  @@unique([shopId, sku])
  @@index([shopId, name])
  @@index([shopId, isActive])
}

// ─────────────────────────────────────────────────────────────
// STOCK HISTORY  (every stock movement logged)
// ─────────────────────────────────────────────────────────────

model StockHistory {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockType
  quantity  Int        // positive = stock in, negative = stock out
  note      String?
  createdAt DateTime  @default(now())

  @@index([productId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────────────────────

model Customer {
  id                 String    @id @default(cuid())
  shopId             String
  shop               Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name               String
  phone              String?
  email              String?
  address            String?
  gstNumber          String?
  outstandingBalance Decimal   @default(0) @db.Decimal(10, 2)
  totalPurchases     Decimal   @default(0) @db.Decimal(10, 2)
  loyaltyPoints      Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orders  Order[]

  @@index([shopId, phone])
  @@index([shopId, name])
}

// ─────────────────────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────────────────────

model Supplier {
  id                 String     @id @default(cuid())
  shopId             String
  shop               Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name               String
  phone              String?
  email              String?
  address            String?
  gstNumber          String?
  outstandingBalance Decimal    @default(0) @db.Decimal(10, 2)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  purchases  Purchase[]

  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// ORDER  (sale / invoice)
// ─────────────────────────────────────────────────────────────

model Order {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  invoiceNumber  String
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentMethod @default(CASH)
  paymentStatus  PaymentStatus @default(PAID)
  status         OrderStatus   @default(COMPLETED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items  OrderItem[]

  @@unique([shopId, invoiceNumber])
  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([shopId, customerId])
}

// ─────────────────────────────────────────────────────────────
// ORDER ITEM  (price snapshot at time of sale)
// ─────────────────────────────────────────────────────────────

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String   // product name snapshot
  quantity  Int
  costPrice Decimal  @db.Decimal(10, 2)  // for profit calc
  unitPrice Decimal  @db.Decimal(10, 2)  // selling price snapshot
  taxRate   Decimal  @default(0) @db.Decimal(5, 2)
  discount  Decimal  @default(0) @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// PURCHASE  (buying stock from supplier)
// ─────────────────────────────────────────────────────────────

model Purchase {
  id            String        @id @default(cuid())
  shopId        String
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplierId    String
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  billNumber    String?
  totalAmount   Decimal       @db.Decimal(10, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PAID)
  purchaseDate  DateTime      @default(now())
  notes         String?
  createdAt     DateTime      @default(now())

  items  PurchaseItem[]

  @@index([shopId, purchaseDate])
  @@index([shopId, supplierId])
}

// ─────────────────────────────────────────────────────────────
// PURCHASE ITEM
// ─────────────────────────────────────────────────────────────

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  costPrice  Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
}

// ─────────────────────────────────────────────────────────────
// EXPENSE  (outgoing business costs)
// ─────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  @@index([shopId, date])
  @@index([shopId, category])
}

