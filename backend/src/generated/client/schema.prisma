// ============================================================
//  Shop OS — Prisma Schema
//  Database: PostgreSQL
//  ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum CouponType {
  PERCENTAGE
  FLAT
  FIRST_ORDER
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum StockType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CREDIT
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum KitchenStatus {
  NONE
  PENDING
  PREPARING
  READY
  COMPLETED
}

enum ExpenseCategory {
  RENT
  ELECTRICITY
  SALARY
  MAINTENANCE
  MARKETING
  TRANSPORT
  OTHER
}

// ─────────────────────────────────────────────────────────────
// SHOP  (multi-tenant root)
// ─────────────────────────────────────────────────────────────

model Shop {
  id              String    @id @default(cuid())
  name            String
  ownerName       String
  phone           String
  email           String
  gstNumber       String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  currency        String    @default("INR")
  timezone        String    @default("Asia/Kolkata")
  logoUrl         String?
  plan            Plan      @default(STARTER)
  planExpiry      DateTime?
  isActive        Boolean   @default(true)
  pricingEnabled  Boolean   @default(false)
  pricingRules    Json?     @default("{}")
  invoiceSettings Json?     @default("{}")
  loyaltyRate     Float     @default(0.1)

  redeemRate   Float    @default(10)
  invoiceCount Int      @default(0)
  mode         String   @default("INDEPENDENT") // INDEPENDENT | FRANCHISE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users             User[]
  categories        Category[]
  products          Product[]
  customers         Customer[]
  suppliers         Supplier[]
  orders            Order[]
  purchases         Purchase[]
  expenses          Expense[]
  memberships       Membership[] // New relation
  coupons           Coupon[] // Growth Engine
  campaigns         Campaign[] // Growth Engine
  brandProfile      BrandProfile? // Marketing OS
  scheduledContents ScheduledContent[] // Marketing OS
  dailyIntel        DailyMarketingIntel[] // Marketing OS
  productOverrides  BranchProductOverride[]
  combos            Combo[]
  comboOverrides    BranchComboOverride[]

  // Franchise Mode (nullable — null = Independent)
  organizationId String? // null = independent shop
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  orgMemberships OrgMembership[] // HQ staff access

  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
// USER  (staff accounts per shop)
// ─────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  shopId              String // Legacy: Primary shop ID
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name                String
  email               String    @unique // GLOBAL IDENTITY: One email per user
  passwordHash        String
  role                Role      @default(EMPLOYEE) // Legacy: Primary role
  isEmailVerified     Boolean   @default(false)
  verifyToken         String?
  resetToken          String?
  resetExpiry         DateTime?
  lastLogin           DateTime?
  isActive            Boolean   @default(true)
  onboardingCompleted Boolean   @default(true) // Default to true for backward comp.
  selectedMode        String? // INDEPENDENT | FRANCHISE
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orders      Order[]
  memberships Membership[] // New relation

  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// MEMBERSHIP  (User roles within specific shops)
// ─────────────────────────────────────────────────────────────

model Membership {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  role      Role     @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([userId])
  @@index([shopId, isActive, role])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  products Product[]

  @@unique([shopId, name])
  @@index([shopId, order])
}

// ─────────────────────────────────────────────────────────────
// PRODUCT  (inventory)
// ─────────────────────────────────────────────────────────────

model Product {
  id            String                  @id @default(cuid())
  shopId        String
  shop          Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?               @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  sku           String?
  barcode       String?
  description   String?
  costPrice     Decimal                 @db.Decimal(10, 2)
  sellingPrice  Decimal                 @db.Decimal(10, 2)
  taxRate       Decimal                 @default(0) @db.Decimal(5, 2)
  stock         Int                     @default(0)
  lowStockAlert Int                     @default(10)
  unit          String                  @default("pcs")
  imageUrl      String?
  isActive      Boolean                 @default(true)
  isAvailable   Boolean                 @default(true)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  overrides     BranchProductOverride[]

  orderItems    OrderItem[]
  purchaseItems PurchaseItem[]
  stockHistory  StockHistory[]
  comboItems    ComboItem[]

  @@unique([shopId, sku])
  @@index([shopId, isActive, isAvailable, createdAt])
  @@index([shopId, stock, lowStockAlert])
  @@index([shopId, name])
  @@index([shopId, categoryId])
}

// ─────────────────────────────────────────────────────────────
// COMBO  (bundled products)
// ─────────────────────────────────────────────────────────────

model Combo {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  organizationId String? // HQ link
  name           String
  description    String?
  imageUrl       String?
  fixedPrice     Decimal  @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  showInScanner  Boolean  @default(true)
  showInPOS      Boolean  @default(true)
  startTime      String? // "HH:mm"
  endTime        String? // "HH:mm"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items      ComboItem[]
  orderItems OrderItem[]
  overrides  BranchComboOverride[]

  @@index([shopId, isActive])
  @@index([organizationId])
}

model ComboItem {
  id        String  @id @default(cuid())
  comboId   String
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@index([comboId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// STOCK HISTORY  (every stock movement logged)
// ─────────────────────────────────────────────────────────────

model StockHistory {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockType
  quantity  Int // positive = stock in, negative = stock out
  note      String?
  createdAt DateTime  @default(now())

  @@index([productId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────────────────────

model Customer {
  id                 String   @id @default(cuid())
  shopId             String
  shop               Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name               String
  phone              String?
  email              String?
  address            String?
  gstNumber          String?
  outstandingBalance Decimal  @default(0) @db.Decimal(10, 2)
  totalPurchases     Decimal  @default(0) @db.Decimal(10, 2)
  loyaltyPoints      Int      @default(0)
  walletBalance      Decimal  @default(0) @db.Decimal(10, 2) // Growth Engine: cashback wallet
  campaignOptOut     Boolean  @default(false) // Growth Engine: opt-out flag
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders Order[]

  @@index([shopId])
  @@index([shopId, phone])
  @@index([shopId, name])
  @@index([shopId, outstandingBalance])
}

// ─────────────────────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────────────────────

model Supplier {
  id                 String   @id @default(cuid())
  shopId             String
  shop               Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name               String
  phone              String?
  email              String?
  address            String?
  gstNumber          String?
  outstandingBalance Decimal  @default(0) @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  purchases Purchase[]

  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// ORDER  (sale / invoice)
// ─────────────────────────────────────────────────────────────

model Order {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  invoiceNumber  String
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentMethod @default(CASH)
  paymentStatus  PaymentStatus @default(PAID)
  status         OrderStatus   @default(COMPLETED)
  kitchenStatus  KitchenStatus @default(NONE)
  notes          String?
  couponId       String? // Growth Engine: applied coupon
  couponDiscount Decimal       @default(0) @db.Decimal(10, 2) // Growth Engine: coupon savings
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items  OrderItem[]
  coupon Coupon?     @relation(fields: [couponId], references: [id])

  @@index([shopId, createdAt, status])
  @@index([shopId, kitchenStatus, createdAt])
  @@index([shopId, invoiceNumber])
  @@index([shopId, customerId])
  @@index([shopId, notes])
}

// ─────────────────────────────────────────────────────────────
// ORDER ITEM  (price snapshot at time of sale)
// ─────────────────────────────────────────────────────────────

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  comboId   String?
  combo     Combo?   @relation(fields: [comboId], references: [id])
  name      String // product/combo name snapshot
  quantity  Int
  costPrice Decimal  @db.Decimal(10, 2) // for profit calc
  unitPrice Decimal  @db.Decimal(10, 2) // selling price snapshot
  taxRate   Decimal  @default(0) @db.Decimal(5, 2)
  discount  Decimal  @default(0) @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)

  @@index([orderId, productId])
  @@index([productId])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────
// PURCHASE  (buying stock from supplier)
// ─────────────────────────────────────────────────────────────

model Purchase {
  id            String        @id @default(cuid())
  shopId        String
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplierId    String
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  billNumber    String?
  totalAmount   Decimal       @db.Decimal(10, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(PAID)
  purchaseDate  DateTime      @default(now())
  notes         String?
  createdAt     DateTime      @default(now())

  items PurchaseItem[]

  @@index([shopId, purchaseDate])
  @@index([shopId, supplierId])
}

// ─────────────────────────────────────────────────────────────
// PURCHASE ITEM
// ─────────────────────────────────────────────────────────────

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  costPrice  Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
}

// ─────────────────────────────────────────────────────────────
// EXPENSE  (outgoing business costs)
// ─────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  description String?
  date        DateTime        @default(now())
  deletedAt   DateTime? // Soft delete for financial audit trail
  createdAt   DateTime        @default(now())

  @@index([shopId, date, category, amount, deletedAt])
  @@index([shopId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// GROWTH ENGINE — Coupon
// ─────────────────────────────────────────────────────────────

model Coupon {
  id          String     @id @default(cuid())
  shopId      String
  shop        Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code        String
  type        CouponType @default(PERCENTAGE)
  value       Decimal    @db.Decimal(10, 2) // % or flat ₹ amount
  minOrder    Decimal    @default(0) @db.Decimal(10, 2)
  maxUses     Int? // null = unlimited
  usedCount   Int        @default(0)
  isFirstOnly Boolean    @default(false)
  isActive    Boolean    @default(true)
  expiresAt   DateTime?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  usages CouponUsage[]
  orders Order[]

  @@unique([shopId, code])
  @@index([shopId, isActive])
  @@index([code])
}

// ─────────────────────────────────────────────────────────────
// GROWTH ENGINE — Coupon Usage (audit trail)
// ─────────────────────────────────────────────────────────────

model CouponUsage {
  id              String   @id @default(cuid())
  couponId        String
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerId      String?
  orderId         String?  @unique
  discountApplied Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  @@index([couponId])
  @@index([customerId])
}

// ─────────────────────────────────────────────────────────────
// GROWTH ENGINE — Campaign
// ─────────────────────────────────────────────────────────────

model Campaign {
  id            String    @id @default(cuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name          String
  targetSegment String // VIP | INACTIVE_30D | NEW | ALL | FREQUENT
  message       String    @db.Text
  type          String    @default("WHATSAPP") // WHATSAPP | SMS | EMAIL
  status        String    @default("DRAFT") // DRAFT | SCHEDULED | RUNNING | COMPLETED
  scheduledAt   DateTime?
  sentCount     Int       @default(0)
  couponId      String? // optional coupon to attach
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId, status])
  @@index([shopId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// GROWTH ENGINE — Loyalty Tier
// ─────────────────────────────────────────────────────────────

model LoyaltyTier {
  id           String   @id @default(cuid())
  shopId       String
  name         String
  minPoints    Int
  discountRate Float    @default(0)
  badgeColor   String   @default("#7c3aed")
  createdAt    DateTime @default(now())

  @@index([shopId, minPoints])
}

// ─────────────────────────────────────────────────────────────
// AI MARKETING OS — Brand & Strategy
// ─────────────────────────────────────────────────────────────

model BrandProfile {
  id             String  @id @default(cuid())
  shopId         String  @unique
  shop           Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  brandType      String  @default("PREMIUM_CAFE") // YOUTH, FAMILY, BUDGET, LUXURY
  toneOfVoice    String  @default("PROFESSIONAL")
  targetAudience String?
  primaryColor   String  @default("#000000")
  secondaryColor String?
  logoUrl        String?
  socialLinks    Json? // {"instagram": "...", "facebook": "..."}
}

model ScheduledContent {
  id           String    @id @default(cuid())
  shopId       String
  shop         Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title        String
  contentBody  String    @db.Text
  imageUri     String?
  contentType  String // REEL, POST, FLYER, EMAIL
  status       String    @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([shopId, scheduledFor, status])
}

model DailyMarketingIntel {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date // Ensures one entry per day per shop
  planText    String   @db.Text
  keyFocus    String?
  actionItems Json // Array of specific tasks

  @@unique([shopId, date])
}

// ═══════════════════════════════════════════════════════
// FRANCHISE / DUAL MODE — Organization Layer
// ═══════════════════════════════════════════════════════

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // e.g., "the-coffee-chain"
  logoUrl   String?
  plan      Plan     @default(PRO) // Orgs start on PRO minimum
  isActive  Boolean  @default(true)
  settings  Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches      Shop[] // All franchise branches
  members       OrgMembership[] // HQ staff
  snapshots     OrgDailySnapshot[] // Pre-aggregated analytics
  menuTemplates MenuTemplate[] // Central product catalog
  menuSyncJobs  MenuSyncJob[]

  @@index([isActive])
}

model OrgMembership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shopId         String? // null = org-wide access (HQ Admin)
  shop           Shop?        @relation(fields: [shopId], references: [id])
  userId         String
  orgRole        String       @default("BRANCH_MANAGER") // HQ_ADMIN | REGIONAL_MANAGER | BRANCH_MANAGER
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId, shopId])
  @@index([organizationId, orgRole])
  @@index([userId])
}

model OrgDailySnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  totalRevenue   Decimal      @db.Decimal(12, 2)
  totalOrders    Int
  totalCustomers Int
  bestBranchId   String?
  bestBranchRev  Decimal?     @db.Decimal(12, 2)
  branchData     Json // Array of per-branch snapshots
  createdAt      DateTime     @default(now())

  @@unique([organizationId, date])
  @@index([organizationId, date])
}

model MenuTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  items          Json // Array of product definitions to push
  isActive       Boolean      @default(true)
  syncMode       String       @default("ADDITIVE") // ADDITIVE | REPLACE
  lastSyncedAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  syncJobs MenuSyncJob[]

  @@index([organizationId, isActive])
}

model MenuSyncJob {
  id              String    @id @default(cuid())
  organizationId  String
  templateId      String
  targetBranchIds Json // Array of shop IDs
  mode            String    @default("ADDITIVE")
  status          String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  result          Json? // Summary of applied changes
  error           String?
  scheduledFor    DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     MenuTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model BranchProductOverride {
  id             String   @id @default(cuid())
  shopId         String
  productId      String
  customPrice    Decimal? @db.Decimal(10, 2)
  customIsActive Boolean?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
  @@index([shopId])
}

model BranchComboOverride {
  id             String   @id @default(cuid())
  shopId         String
  comboId        String
  customPrice    Decimal? @db.Decimal(10, 2)
  customIsActive Boolean?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  combo Combo @relation(fields: [comboId], references: [id], onDelete: Cascade)

  @@unique([shopId, comboId])
  @@index([shopId])
}
